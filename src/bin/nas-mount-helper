#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
APPLY_SCRIPT="${PROJECT_ROOT}/libexec/nas-mount-helper-apply"
INSTALL_CIFS_SCRIPT="${PROJECT_ROOT}/libexec/nas-mount-helper-install-cifs-utils"
temp_file=""
nas_host="${nas_host:-}"
share_name="${share_name:-}"
mount_name="${mount_name:-}"
username="${username:-}"
password="${password:-}"
domain="${domain:-}"
uid="${uid:-}"
gid="${gid:-}"
smb_version="${smb_version:-3.0}"

list_existing_mounts() {
  if [[ ! -r /etc/fstab ]]; then
    return 0
  fi

  awk '/^# nas-mount-helper begin / { print $4 }' /etc/fstab
}

load_existing_config() {
  local selected_mount="$1"
  local entry remote options option

  entry="$(awk -v begin="# nas-mount-helper begin ${selected_mount}" '
    $0 == begin {
      getline
      print
      exit
    }
  ' /etc/fstab)"

  if [[ -z "${entry}" ]]; then
    return 1
  fi

  read -r remote _ _ options _ <<<"${entry}"

  nas_host="${remote#//}"
  share_name="${nas_host#*/}"
  nas_host="${nas_host%%/*}"
  mount_name="${selected_mount}"
  username=""
  password=""
  domain=""
  uid=""
  gid=""
  smb_version="3.0"

  IFS=',' read -r -a option_list <<<"${options}"
  for option in "${option_list[@]}"; do
    case "${option}" in
      uid=*) uid="${option#uid=}" ;;
      gid=*) gid="${option#gid=}" ;;
      vers=*) smb_version="${option#vers=}" ;;
    esac
  done
}

reset_form_values() {
  nas_host=""
  share_name=""
  mount_name=""
  username=""
  password=""
  domain=""
  uid=""
  gid=""
  smb_version="3.0"
}

normalize_mount_name() {
  local value="$1"
  value="${value%%|*}"
  value="${value//$'\r'/}"
  value="${value//$'\n'/}"
  value="${value// /}"
  printf '%s' "${value}"
}

require_command() {
  local cmd="$1"
  if ! command -v "${cmd}" >/dev/null 2>&1; then
    if command -v yad >/dev/null 2>&1; then
      yad --error \
        --title="nas-mount-helper" \
        --width=520 \
        --text="必須コマンド '${cmd}' が見つかりません。"
    else
      echo "Required command missing: ${cmd}" >&2
    fi
    exit 1
  fi
}

encode_base64() {
  local value="$1"
  printf '%s' "${value}" | base64 | tr -d '\n'
}

show_error() {
  local message="$1"
  yad --error --title="nas-mount-helper" --width=520 --text="${message}"
}

show_info() {
  local message="$1"
  yad --info --title="nas-mount-helper" --width=520 --text="${message}"
}

format_test_error() {
  local raw="$1"
  local hint="接続テストに失敗しました。"

  if [[ "${raw}" == *NT_STATUS_LOGON_FAILURE* || "${raw}" == *NT_STATUS_ACCESS_DENIED* ]]; then
    hint="認証に失敗しました。ユーザー名、パスワード、ドメインを確認してください。"
  elif [[ "${raw}" == *NT_STATUS_BAD_NETWORK_NAME* || "${raw}" == *"tree connect failed"* || "${raw}" == *ERRbadpath* ]]; then
    hint="共有名が見つかりません。共有名の入力を確認してください。"
  elif [[ "${raw}" == *NT_STATUS_HOST_UNREACHABLE* || "${raw}" == *"No route to host"* || "${raw}" == *"Connection refused"* || "${raw}" == *"Operation now in progress"* ]]; then
    hint="NAS に接続できません。ホスト名または IP、ネットワーク状態を確認してください。"
  elif [[ "${raw}" == *NT_STATUS_IO_TIMEOUT* || "${raw}" == *"timed out"* ]]; then
    hint="NAS への接続がタイムアウトしました。NAS の起動状態やネットワークを確認してください。"
  elif [[ "${raw}" == *NT_STATUS_NOT_SUPPORTED* || "${raw}" == *"protocol negotiation failed"* || "${raw}" == *"SMB1 disabled"* || "${raw}" == *"Max protocol"* ]]; then
    hint="SMB バージョンが合っていない可能性があります。SMB バージョンの入力を確認してください。"
  elif [[ "${raw}" == *"could not resolve"* || "${raw}" == *"Name or service not known"* ]]; then
    hint="NAS ホスト名を解決できません。ホスト名または IP の入力を確認してください。"
  fi

  printf '%s\n\n詳細:\n%s' "${hint}" "${raw}"
}

show_question() {
  local title="$1"
  local ok_label="$2"
  local cancel_label="$3"
  local message="$4"

  yad --question \
    --title="${title}" \
    --width=520 \
    --button="${cancel_label}:1" \
    --button="${ok_label}:0" \
    --text="${message}"
}

select_existing_mount() {
  local title="$1"
  shift

  yad --list \
    --title="${title}" \
    --width=480 \
    --height=300 \
    --column="マウント名" \
    "$@"
}

select_existing_or_new() {
  local -a rows
  rows=("新規作成")
  rows+=("$@")

  select_existing_mount "既存設定または新規作成を選択" "${rows[@]}"
}

prompt_existing_action() {
  local selected_mount="$1"

  yad --question \
    --title="NAS Mount Helper" \
    --width=520 \
    --button="戻る:1" \
    --button="削除:3" \
    --button="編集:0" \
    --text="選択した設定:\n\n${selected_mount}\n\nこの設定をどうしますか？"
}

prompt_terminal_install() {
  local package_list="$1"
  printf '%s\n' "次のパッケージが必要です: ${package_list}" >/dev/tty
  printf '%s' "インストールしますか? [y/N]: " >/dev/tty
  read -r reply </dev/tty
  [[ "${reply:-}" =~ ^[Yy]$ ]]
}

install_runtime_dependencies() {
  local missing=()
  local missing_text

  command -v yad >/dev/null 2>&1 || missing+=("yad")
  command -v smbclient >/dev/null 2>&1 || missing+=("smbclient")
  command -v mount.cifs >/dev/null 2>&1 || missing+=("cifs-utils")

  if [[ "${#missing[@]}" -eq 0 ]]; then
    return 0
  fi

  missing_text="${missing[*]}"

  if command -v yad >/dev/null 2>&1; then
    yad --question \
      --title="依存パッケージをインストール" \
      --width=520 \
      --button="中止:1" \
      --button="インストールする:0" \
      --text="次のパッケージが必要です。\n\n${missing_text}\n\nJetPack 5.1 (Ubuntu 20.04) に自動インストールしますか？" || exit 0

    show_info "これから管理者権限で必要パッケージをインストールします。認証ダイアログが表示された後、完了まで少し待ってください。"
  else
    prompt_terminal_install "${missing_text}" || exit 0
  fi

  if ! pkexec "${INSTALL_CIFS_SCRIPT}"; then
    if command -v yad >/dev/null 2>&1; then
      show_error "依存パッケージのインストールに失敗しました。ネットワーク接続と apt の状態を確認してください。"
    else
      echo "Failed to install required packages." >&2
    fi
    exit 1
  fi

  require_command yad
  require_command smbclient
  require_command mount.cifs

  show_info "必要パッケージのインストールが完了しました。設定を続行します。"
}

map_smbclient_protocol() {
  case "${smb_version}" in
    1* ) printf '%s' "NT1" ;;
    2* ) printf '%s' "SMB2" ;;
    * ) printf '%s' "SMB3" ;;
  esac
}

test_connection_nonroot() {
  local auth_file
  local max_protocol

  auth_file="$(mktemp)"

  cleanup_test_auth() {
    rm -f "${auth_file}"
  }

  trap cleanup_test_auth RETURN

  {
    printf 'username = %s\n' "${username}"
    printf 'password = %s\n' "${password}"
    if [[ -n "${domain}" ]]; then
      printf 'domain = %s\n' "${domain}"
    fi
  } >"${auth_file}"

  chmod 600 "${auth_file}"
  max_protocol="$(map_smbclient_protocol)"

  if [[ "${max_protocol}" == "NT1" ]]; then
    smbclient "//${nas_host}/${share_name}" \
      --authentication-file="${auth_file}" \
      --max-protocol="${max_protocol}" \
      --option='client min protocol = NT1' \
      -c 'ls'
  else
    smbclient "//${nas_host}/${share_name}" \
      --authentication-file="${auth_file}" \
      --max-protocol="${max_protocol}" \
      -c 'ls'
  fi
}

prompt_form() {
  yad --form \
    --title="NAS Mount Helper" \
    --text="Ubuntu に NAS を永続マウントします" \
    --separator="|" \
    --width=540 \
    --field="NAS ホスト名または IP" \
    --field="共有名" \
    --field="マウント名 (/mnt 配下)" \
    --field="ユーザー名" \
    --field="パスワード:H" \
    --field="ドメイン (任意)" \
    --field="UID (任意, 例: 1000)" \
    --field="GID (任意, 例: 1000)" \
    --field="SMB バージョン" \
    "${nas_host}" \
    "${share_name}" \
    "${mount_name}" \
    "${username}" \
    "${password}" \
    "${domain}" \
    "${uid}" \
    "${gid}" \
    "${smb_version}"
}

build_summary() {
  cat <<EOF
NAS ホスト: ${nas_host}
共有名: ${share_name}
マウント先: /mnt/${mount_name}
ユーザー名: ${username}
ドメイン: ${domain:-未指定}
UID: ${uid:-未指定}
GID: ${gid:-未指定}
SMB バージョン: ${smb_version}
EOF
}

validate_inputs() {
  if [[ -z "${nas_host}" || -z "${share_name}" || -z "${mount_name}" || -z "${username}" || -z "${password}" ]]; then
    show_error "必須項目が未入力です。"
    return 1
  fi

  if [[ ! "${mount_name}" =~ ^[A-Za-z0-9._-]+$ ]]; then
    show_error "マウント名は英数字、ドット、ハイフン、アンダースコアのみ使えます。"
    return 1
  fi

  if [[ -z "${smb_version}" ]]; then
    smb_version="3.0"
  fi
}

write_temp_config() {
  temp_file="$(mktemp)"
  chmod 600 "${temp_file}"

  cat >"${temp_file}" <<EOF
NAS_HOST_B64=$(encode_base64 "${nas_host}")
SHARE_NAME_B64=$(encode_base64 "${share_name}")
MOUNT_NAME_B64=$(encode_base64 "${mount_name}")
USERNAME_B64=$(encode_base64 "${username}")
PASSWORD_B64=$(encode_base64 "${password}")
DOMAIN_B64=$(encode_base64 "${domain}")
UID_VALUE_B64=$(encode_base64 "${uid}")
GID_VALUE_B64=$(encode_base64 "${gid}")
SMB_VERSION_B64=$(encode_base64 "${smb_version}")
EOF
}

cleanup_temp_config() {
  if [[ -n "${temp_file:-}" && -f "${temp_file}" ]]; then
    rm -f "${temp_file}"
  fi
}

require_command pkexec
require_command base64
install_runtime_dependencies

trap cleanup_temp_config EXIT
show_main_menu=1

while true; do
  if [[ "${show_main_menu}" -eq 1 ]]; then
    mapfile -t existing_mounts < <(list_existing_mounts)

    if [[ "${#existing_mounts[@]}" -gt 0 ]]; then
      selected_mount="$(select_existing_or_new "${existing_mounts[@]}")" || exit 0
      selected_mount="$(normalize_mount_name "${selected_mount}")"

      if [[ "${selected_mount}" == "新規作成" ]]; then
        reset_form_values
      else
        set +e
        prompt_existing_action "${selected_mount}"
        action_code="$?"
        set -e

        case "${action_code}" in
          0)
            if ! load_existing_config "${selected_mount}"; then
              show_error "既存設定を読み込めませんでした。"
              continue
            fi
            show_info "既存設定を読み込みました。ユーザー名とパスワードは再入力してください。"
            ;;
          1)
            continue
            ;;
          3)
            if ! show_question "設定削除" "削除する" "戻る" "次の設定を削除します。\n\nマウント名: ${selected_mount}\nマウント先: /mnt/${selected_mount}"; then
              continue
            fi

            if delete_output="$(pkexec "${APPLY_SCRIPT}" delete "${selected_mount}" 2>&1)"; then
              show_info "設定を削除しました。\n\n${delete_output}"
            else
              show_error "設定の削除に失敗しました。\n\n${delete_output}"
            fi
            continue
            ;;
          *)
            continue
            ;;
        esac
      fi
    else
      reset_form_values
    fi

    show_main_menu=0
  fi

  form_output="$(prompt_form)" || {
    show_main_menu=1
    continue
  }

  IFS='|' read -r nas_host share_name mount_name username password domain uid gid smb_version <<<"${form_output}"

  nas_host="${nas_host// /}"
  share_name="${share_name// /}"
  mount_name="${mount_name// /}"
  username="${username// /}"
  uid="${uid// /}"
  gid="${gid// /}"
  smb_version="${smb_version// /}"

  if ! validate_inputs; then
    continue
  fi

  summary="$(build_summary)"

  if ! show_question "内容確認" "接続テストへ進む" "入力へ戻る" "${summary}"; then
    continue
  fi

  cleanup_temp_config
  write_temp_config

  if test_output="$(test_connection_nonroot 2>&1)"; then
    if ! show_question "接続テスト成功" "この内容で保存する" "入力へ戻る" "接続テストに成功しました。\n\n${summary}"; then
      continue
    fi
  else
    show_error "$(format_test_error "${test_output}")"
    continue
  fi

  if apply_output="$(pkexec "${APPLY_SCRIPT}" apply "${temp_file}" 2>&1)"; then
    show_info "設定が完了しました。/mnt/${mount_name} をその場でマウントできました。"
    exit 0
  else
    show_error "設定の保存またはマウントに失敗しました。\n\n${apply_output}"
  fi
done
